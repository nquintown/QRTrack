datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model QrCode {
  id          String   @id @default(cuid())
  shortId     String   @unique
  originalUrl String
  createdAt   DateTime @default(now())
  scans       Scan[]
}

model Scan {
  id        String   @id @default(cuid())
  qrCodeId  String
  scannedAt DateTime @default(now())
  userAgent String?
  qrCode    QrCode   @relation(fields: [qrCodeId], references: [id])
}
