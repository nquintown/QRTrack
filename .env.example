# Base de données PostgreSQL (ex: Neon)
# Sur Vercel : connecter l'intégration Neon depuis le dashboard
# DATABASE_URL = connection pooling (utilisé par Prisma en serverless)
# DIRECT_URL   = connexion directe (utilisé par prisma db push / migrate)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"
